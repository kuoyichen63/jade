rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety check helpers
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isValidGameRecord(data) {
      return data.keys().hasAll(['username', 'startTime', 'totalDiscovered', 'correctCount', 'incorrectCount', 'accuracy', 'durationSeconds'])
        && data.username is string && data.username.size() <= 128
        && data.startTime is string && data.startTime.size() <= 128
        && data.totalDiscovered is int && data.totalDiscovered >= 0
        && data.correctCount is int && data.correctCount >= 0
        && data.incorrectCount is int && data.incorrectCount >= 0
        && (data.accuracy is int || data.accuracy is float) && data.accuracy >= 0
        && data.durationSeconds is int && data.durationSeconds >= 0;
    }

    function isValidAdminSettings(data) {
      return data.keys().hasAll(['password'])
        && data.password is string && data.password.size() <= 128;
    }

    // Match game records
    match /records/{recordId} {
      allow read, delete: if true;
      allow create: if isValidId(recordId) && isValidGameRecord(request.resource.data);
      allow update: if isValidId(recordId) && isValidGameRecord(request.resource.data);
    }

    // Match admin configuration
    match /system/{docId} {
      allow read: if true;
      allow write: if docId == 'admin_config' && isValidAdminSettings(request.resource.data);
    }
  }
}
